Algoritmo "OperadoresLogicosRelacionais"

Var
   A,B,C: Inteiro


Inicio
    A <- 2
    B <- 3
    C <- 5
    Escreval(" A È maior que B: ", A>B)
    Escreval(" A È menor que B: ", A<B)
    Escreval(" B È menor ou igual a C: ", B<=C)
    Escreval (" C È maior ou igual a A: ", C>=A)
    Escreval(" A È dirente de B: ", A<>B)
    Escreval (" C È igual a B: ", C=B)
    
Fimalgoritmo